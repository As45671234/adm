# Nginx config for ADM Mebel
# Скопировай это в: /etc/nginx/sites-available/adm
# Затем: sudo ln -s /etc/nginx/sites-available/adm /etc/nginx/sites-enabled/adm

upstream backend {
    server localhost:3001;
}

server {
    listen 80;
    server_name adm-mebel-astana.kz www.adm-mebel-astana.kz;

    # Redirect HTTP to HTTPS (раскомментировать после SSL setup)
    # return 301 https://$server_name$request_uri;

    root /home/ubuntu/adm/frontend/dist;
    index index.html;

    # Gzip compression
    gzip on;
    gzip_types text/css text/javascript application/json application/javascript;
    gzip_min_length 1000;
    gzip_disable "msie6";

    # Frontend SPA routing
    location / {
        try_files $uri $uri/ /index.html;
        expires 1h;
        add_header Cache-Control "public";
    }

    # API proxy to backend
    location /api/ {
        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Serve uploaded product images with cache
    location /uploads/ {
        alias /home/ubuntu/adm/backend/uploads/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Static assets caching
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Deny access to node_modules and hidden files
    location ~ /\. {
        deny all;
    }
    location ~ /node_modules/ {
        deny all;
    }
}

